# Variables d'environnement pour l'agent SRE EFK
# IMPORTANT: Ce fichier contient des exemples. Ne jamais committer de vraies valeurs!

# Configuration Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=changeme-replace-with-real-password
METRICS_INDEX=metricbeat-*
LOGS_INDEX=fluentd-*

# Configuration Kubernetes
K8S_IN_CLUSTER=true
K8S_NAMESPACE=monitoring

# Configuration de l'analyse
ANALYSIS_INTERVAL=300
ANOMALY_THRESHOLD=0.05

# Seuils d'alerte
CPU_THRESHOLD_WARNING=70.0
CPU_THRESHOLD_CRITICAL=85.0
MEMORY_THRESHOLD_WARNING=70.0
MEMORY_THRESHOLD_CRITICAL=85.0

# Configuration des modèles ML
MODEL_RETRAIN_INTERVAL=3600
MODEL_WINDOW_SIZE=100

# Configuration LLM (optionnel - pour améliorer l'interprétation des événements)
LLM_ENABLED=false
LLM_PROVIDER=openai  # openai, anthropic, ollama
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=gpt-3.5-turbo  # ou gpt-4, claude-3-sonnet-20240229, llama2, etc.
LLM_BASE_URL=http://localhost:11434  # Pour Ollama uniquement
LLM_MAX_TOKENS=1000
LLM_TEMPERATURE=0.1

# Alerting (laisser vide si non utilisé)
WEBHOOK_URL=
SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your-email@example.com
EMAIL_PASSWORD=your-app-password
EMAIL_RECIPIENTS=sre-team@example.com,alerts@example.com

# Logging
LOG_LEVEL=INFO